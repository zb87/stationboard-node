{
  "name": "stationboard",
  "version": "1.0.0",
  "description": "API proxy for Swiss public transport timetables (OJP 2.0)",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "node --test test/**/*.test.js",
    "web:install": "cd web && npm install",
    "web:dev": "cd web && npm run dev",
    "web:build": "cd web && npm run build"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "express": "^4.21.0",
    "fast-xml-parser": "^4.5.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
